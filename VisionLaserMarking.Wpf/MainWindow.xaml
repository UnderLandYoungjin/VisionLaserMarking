<Window x:Class="VisionLaserMarking.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="비전 위치보정 레이저 마킹 시뮬레이터" Height="800" Width="700"
        ResizeMode="CanMinimize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Width="640" Height="380" HorizontalAlignment="Left">
            <Image x:Name="SceneImage" Width="640" Height="380" Stretch="None"/>
            <Canvas x:Name="OverlayCanvas" Width="640" Height="380" Background="Transparent"
                    Cursor="Hand" MouseLeftButtonDown="OverlayCanvas_MouseLeftButtonDown"/>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="RegenButton" Content="새 배치" Padding="10,4" Margin="0,0,8,0"
                    Click="RegenButton_Click"/>
            <Button x:Name="DetectButton" Content="경계 검출" Padding="10,4" Margin="0,0,8,0"
                    Click="DetectButton_Click"/>
            <Button x:Name="AutoMarkButton" Content="전체 자동 마킹" Padding="10,4" Margin="0,0,8,0"
                    Click="AutoMarkButton_Click"/>
            <Button x:Name="ManualToggleButton" Content="수동 마킹: OFF" Padding="10,4"
                    Click="ManualToggleButton_Click"/>
        </StackPanel>

        <TextBlock x:Name="HintText" Grid.Row="2" Margin="0,6,0,0" FontSize="11" Foreground="Gray"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
            <TextBlock Text="부품 수" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Slider x:Name="PartCountSlider" Minimum="3" Maximum="8" Value="5" Width="200"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    ValueChanged="PartCountSlider_ValueChanged"/>
            <TextBlock x:Name="PartCountLabel" Text="5" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#F1EFE8" CornerRadius="6" Padding="10" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="검출된 부품" FontSize="11" Foreground="Gray"/>
                    <TextBlock x:Name="DetectedCountText" Text="0" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="#F1EFE8" CornerRadius="6" Padding="10" Margin="3,0,3,0">
                <StackPanel>
                    <TextBlock Text="누적 생산 수량" FontSize="11" Foreground="Gray"/>
                    <TextBlock x:Name="ProducedCountText" Text="0" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="#F1EFE8" CornerRadius="6" Padding="10" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="모드" FontSize="11" Foreground="Gray"/>
                    <TextBlock x:Name="ModeText" Text="자동" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="5" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="검출 결과" FontWeight="Bold" Margin="0,0,0,4"/>
                <ListBox x:Name="PartListBox" Height="170" FontSize="12"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Text="마킹 로그" FontWeight="Bold" Margin="0,0,0,4"/>
                <ListBox x:Name="MarkLogListBox" Height="170" FontSize="12"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
